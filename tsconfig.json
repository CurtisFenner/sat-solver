{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2022",
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "allowJs": true,
    "allowArbitraryExtensions": false,
    "allowImportingTsExtensions": true,
    "sourceMap": true,
    "inlineSources": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "types": [
      "node"
    ],
    "rootDir": "src/",
    "paths": {
      "undici-types": [
        "./node_modules/undici-types/index.d.ts"
      ]
    }
  },
  "include": [
    "src/*.d.ts",
    "src/**/*.ts",
  ]
}
